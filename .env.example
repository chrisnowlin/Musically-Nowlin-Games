# Cadence Quest API + PvP
# Copy to .env and fill in values

# Database (required for character persistence and PvP)
# Get a free Neon Postgres URL at https://neon.tech
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Session secret (required in production)
SESSION_SECRET=your-secret-key-change-in-production

# CORS origin for API/WebSocket (default: Vite dev server)
CORS_ORIGIN=http://localhost:5174

# API port
PORT=3001

# Google OAuth (required for teacher dashboard)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Client-side: API base URL (used by Vite for fetch and WebSocket)
# Must match server origin in dev
VITE_API_URL=http://localhost:3001
